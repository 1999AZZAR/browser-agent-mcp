# ── Browser Agent Environment ─────────────────────────────────────────────────
# Lines starting with # are comments and are ignored.
# Uncomment a variable (remove the #) to activate it.

# Browser start page when the MCP session is launched.
START_URL=duckduckgo.com

# Optional task description exposed to MCP clients.
GOAL=Navigate and interact with the web page autonomously to complete the visible task.

# ── Browser Stability ──────────────────────────────────────────────────────────

# Path to a dedicated Chromium binary. If set, Playwright will use this
# instead of its bundled Chromium. Useful for production deployments
# where you want a specific Chromium build/version.
# CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Playwright channel hint (e.g. "chromium", "chrome", "chrome-beta").
# Ignored if CHROMIUM_EXECUTABLE_PATH is set.
# CHROMIUM_CHANNEL=chromium

# Run the browser headless. Default: false (headful, for interactive debug).
# Set to "true" for CI / production.
# BROWSER_HEADLESS=false

# Number of retries when the browser fails to launch. Default: 3.
# BROWSER_LAUNCH_RETRIES=3

# Base delay (ms) between launch retries; doubled on each retry. Default: 1000.
# BROWSER_LAUNCH_BACKOFF=1000

# ── Security ───────────────────────────────────────────────────────────────────

# Allow navigation to localhost and private IPs (10.x, 192.168.x, 127.x, etc.).
# Default: false (blocked by SSRF protection).
# Enable for local development testing.
# ALLOW_PRIVATE_IPS=false

# Allow all URL schemes (file://, data://, javascript://, etc.).
# Default: false (only http/https allowed).
# Enable for local file access or testing.
# ALLOW_ALL_SCHEMES=false
